# semaAUTH website — environment variables
# Copy to .env.local and adjust for your environment.

# --- Public (browser PKCE client) ---
NEXT_PUBLIC_SEMAAUTH_ISSUER_URL=http://localhost:8080
NEXT_PUBLIC_SEMAAUTH_CLIENT_ID=semaauth_website
NEXT_PUBLIC_SEMAAUTH_REDIRECT_URI=http://localhost:3000/callback
NEXT_PUBLIC_SEMAAUTH_TENANT_ID=00000000-0000-0000-0000-000000000001

# --- Server (BFF routes → backend-core) ---
SEMAAUTH_ISSUER_URL=http://localhost:8080
SEMAAUTH_CLIENT_ID=semaauth_website
SEMAAUTH_TENANT_ID=00000000-0000-0000-0000-000000000001

# Optional: override refresh cookie name (default: semaauth_refresh)
# SEMAAUTH_REFRESH_COOKIE=semaauth_refresh

# --- semaAUTH packages (installed from GitHub in package.json) ---
# https://github.com/semaAUTH/semaauth — branch/path pinned in package.json

# --- Backend prerequisite ---
# Register OAuth client on backend-core (run once):
#   docker exec -i semaauth-postgres psql -U user -d semaauth \
#     < ../semaauth/backend-core/migrations/012_semaauth_website_client.sql
# Or: make setup in the semaauth repo (includes migration 012)
